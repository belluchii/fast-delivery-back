{
  "name": "fast-delivery-back",
  "version": "2.0.4",
  "description": "fast-delivery-back",
  "engines": {
    "node": ">=24.0.0"
  },
  "main": "dist/server",
  "scripts": {
    "start": "node dist/server",
    "dev": "nodemon --exec ts-node --files server.ts",
    "lint": "eslint .",
    "test": "jest --verbose",
    "build": "tsc --outDir ./dist",
    "deploy": "npm run build && sls deploy"
  },
  "author": "golfito red",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.0",
    "serverless": "^4.33.0",
    "serverless-http": "^4.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "typescript": "^5.7.0",
    "validator": "^13.12.0"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.22.9",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/validator": "^13.12.2",
    "@typescript-eslint/eslint-plugin": "^6.1.0",
    "eslint": "^8.45.0",
    "eslint-plugin-cypress": "^2.13.3",
    "eslint-plugin-jest": "^27.2.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.9",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2"
  },
  "directories": {
    "doc": "docs"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run lint"
    }
  },
  "keywords": [],
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.ts"
    ],
    "testTimeout": 60000
  }
}
